# git easy checkout main and pull
gitm() {
  git show-ref --verify --quiet refs/heads/main && git checkout main &&
  git pull
}

# git easy rebase
gitr() {
  [ -z "$1" ] && echo "No commit distance from HEAD provided" && return
  git add -A && git commit --no-verify -m "gitr: set rebase command 'f' to fixup"
  git rebase -i HEAD~$1
}

# git easy rebase against branch
gitrb() {
  BRANCH=$(git rev-parse --abbrev-ref HEAD)
  git checkout $1 &&
  git pull origin $1 &&
  git checkout $BRANCH &&
  git rebase $1
}

# git easy add all and commit
gitc() {
  git add -A && git commit --no-verify -m "$@"
}

# git easy push
gitp() {
  git push origin $(git rev-parse --abbrev-ref HEAD) "$@"
}

# git easy no-verify push
gitv() {
  git push origin $(git rev-parse --abbrev-ref HEAD) --no-verify "$@"
}

# git easy fetch and hard replace
gitf() {
  if git rev-parse --is-inside-work-tree &>/dev/null; then
    vared -p "Are you sure you want to fetch and reset branch $(git rev-parse --abbrev-ref HEAD)? (Y/n) " -c REPLY

    if [[ "$REPLY" == [Yy] ]]; then
      git fetch origin && git reset --hard origin/$(git rev-parse --abbrev-ref HEAD)
    fi

    unset REPLY
  fi
}
